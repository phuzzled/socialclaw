# SocialSwag Environment Variables
# Copy this to .env and fill in your values
# NEVER commit .env to version control

# ===========================================
# REQUIRED: X API (X/Twitter)
# ===========================================
# Get your Bearer Token at https://developer.x.com/
X_API_BEARER_TOKEN=your_x_api_bearer_token_here

# ===========================================
# OPTIONAL: OpenRouter AI (default for AI features)
# ===========================================
# Get your API key at https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# Default: x-ai/grok-4.20-beta
# Change to any model from https://openrouter.ai/models
OPENROUTER_MODEL=x-ai/grok-4.20-beta

# ===========================================
# OPTIONAL: OpenAI (fallback if no OpenRouter)
# ===========================================
# Only needed if not using OpenRouter
OPENAI_API_KEY=your_openai_api_key_here

# ===========================================
# OPTIONAL: Google AI (for image generation)
# ===========================================
# Get your API key at https://aistudio.google.com/
# Used for Nano Banana 2 (Gemini 3.1 Flash Image)
GOOGLE_API_KEY=your_google_api_key_here

# ===========================================
# OPTIONAL: Advanced Configuration
# ===========================================
# Custom X API base URL (usually not needed)
# X_API_BASE_URL=https://api.x.com/2

# Request timeout in seconds (default: 30)
# X_TIMEOUT=30

# Max results per request (default: 100)
# X_MAX_RESULTS=100